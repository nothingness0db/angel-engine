{
  "name": "desktop",
  "productName": "Angel Engine",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "description": "Desktop shell for Angel Engine.",
  "author": {
    "name": "akarachen",
    "email": "akarachen@outlook.com"
  },
  "license": "MIT",
  "keywords": [],
  "main": ".vite/build/main.js",
  "scripts": {
    "runtime:build": "pnpm --filter @angel-engine/js-client build && pnpm --filter @angel-engine/claude-client build && pnpm --filter @angel-engine/client-napi build",
    "prestart": "pnpm run runtime:build",
    "start": "electron-forge start",
    "prepackage": "pnpm run runtime:build && pnpm run rebuild:native",
    "package": "electron-forge package",
    "premake": "pnpm run runtime:build && pnpm run rebuild:native",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@angel-engine/client-napi": "workspace:*",
    "@angel-engine/claude-client": "workspace:*",
    "@angel-engine/js-client": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "^0.2.133",
    "@assistant-ui/react": "^0.12.28",
    "@assistant-ui/react-streamdown": "^0.1.11",
    "@egoist/tipc": "^0.3.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/playwrite-de-la": "^5.2.7",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@fontsource/noto-sans-kr": "^5.2.9",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@fontsource/noto-sans-tc": "^5.2.9",
    "@lobehub/icons-static-svg": "^1.90.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@remixicon/react": "^4.9.0",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/react-query": "^5.100.9",
    "ai": "^6.0.175",
    "arktype": "^2.2.0",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "electron-squirrel-startup": "^1.0.1",
    "framer-motion": "^12.38.0",
    "i18next": "^26.1.0",
    "katex": "^0.16.45",
    "mime-types": "^3.0.0",
    "nanoid": "^5.1.11",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-grab": "^0.1.33",
    "react-i18next": "^17.0.7",
    "shadcn": "^4.7.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "tw-shimmer": "^0.4.11",
    "wouter": "^3.9.0",
    "xstate": "^5.31.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/shared-types": "^7.11.1",
    "@electron/fuses": "^2.1.1",
    "@electron/rebuild": "^4.0.4",
    "@eslint-react/eslint-plugin": "^5.7.8",
    "@tailwindcss/vite": "^4.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/mime-types": "^3.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "electron": "41.5.0",
    "eslint": "^10.4.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
